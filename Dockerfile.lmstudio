# LM Studio Docker Image
FROM nvidia/cuda:11.8.0-runtime-ubuntu22.04

# Install dependencies
RUN apt-get update && apt-get install -y \
    curl \
    wget \
    git \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Download and install LM Studio
RUN mkdir -p /app && cd /app

# Note: LM Studio is a desktop app, so we'll use a lightweight alternative
# Install Ollama instead (open-source, works in Docker)
RUN curl -fsSL https://ollama.ai/install.sh | sh

# Expose port
EXPOSE 11434

# Start Ollama
CMD ["ollama", "serve"]
